generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradingSession {
  ASIA
  LONDON
  NEW_YORK
  OTHER
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  accounts      Account[]
  sessions      Session[]
  trades        Trade[]
  setups        Setup[]
  importJobs    ImportJob[]
  aiInsights    AIInsight[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Trade {
  id            String           @id @default(cuid())
  userId        String
  broker        String?
  accountName   String?
  instrument    String
  direction     TradeDirection
  entryTime     DateTime
  exitTime      DateTime?
  entryPrice    Decimal          @db.Decimal(18, 6)
  exitPrice     Decimal?         @db.Decimal(18, 6)
  quantity      Decimal          @db.Decimal(18, 4)
  grossPnl      Decimal?         @db.Decimal(18, 2)
  netPnl        Decimal          @db.Decimal(18, 2)
  commission    Decimal?         @db.Decimal(18, 2)
  fees          Decimal?         @db.Decimal(18, 2)
  riskAmount    Decimal?         @db.Decimal(18, 2)
  rMultiple     Decimal?         @db.Decimal(10, 4)
  stopLoss      Decimal?         @db.Decimal(18, 6)
  takeProfit    Decimal?         @db.Decimal(18, 6)
  session       TradingSession   @default(OTHER)
  setupId       String?
  notes         String?
  emotionBefore String?
  emotionAfter  String?
  mistakeTags   String[]         @default([])
  screenshotUrl String?
  importedFrom  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  setup         Setup?           @relation(fields: [setupId], references: [id], onDelete: SetNull)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, entryTime])
  @@index([userId, instrument])
  @@index([userId, setupId])
  @@index([userId, session])
}

model Setup {
  id                   String   @id @default(cuid())
  userId               String
  name                 String
  description          String?
  rules                Json?
  marketConditions     String?
  entryCriteria        String?
  exitCriteria         String?
  invalidationCriteria String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades               Trade[]

  @@unique([userId, name])
}

model ImportJob {
  id           String          @id @default(cuid())
  userId       String
  source       String
  filename     String
  status       ImportJobStatus @default(PENDING)
  rowsTotal    Int            @default(0)
  rowsImported Int            @default(0)
  rowsFailed   Int            @default(0)
  errorLog     Json?
  createdAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AIInsight {
  id              String   @id @default(cuid())
  userId          String
  insightType     String
  title           String
  summary         String
  evidence        Json
  suggestedAction String
  confidenceScore Decimal  @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, insightType])
}
