generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradingSession {
  ASIA
  LONDON
  NEW_YORK
  OTHER
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BrokerProvider {
  TRADOVATE
}

enum BrokerEnvironment {
  DEMO
  LIVE
}

enum BrokerConnectionStatus {
  CONNECTED
  NEEDS_REAUTH
  ERROR
  DISCONNECTED
}

enum BrokerSyncJobStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  accounts      Account[]
  sessions      Session[]
  trades        Trade[]
  tradingAccounts TradingAccount[]
  setups        Setup[]
  importJobs    ImportJob[]
  aiInsights    AIInsight[]
  brokerConnections BrokerConnection[]
  brokerAccounts    BrokerAccount[]
  brokerSyncJobs    BrokerSyncJob[]
  createdInvites    Invite[]     @relation("InvitesCreated")
  acceptedInvites   Invite[]     @relation("InviteAccepted")
}

model TradingAccount {
  id        String   @id @default(cuid())
  userId    String
  name      String
  broker    String?
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades    Trade[]
  importJobs ImportJob[]
  brokerAccounts BrokerAccount[]

  @@unique([userId, name])
  @@index([userId, createdAt])
}

model Invite {
  id           String    @id @default(cuid())
  email        String
  name         String?
  tokenHash    String    @unique
  invitedById  String?
  acceptedById String?
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  invitedBy    User?     @relation("InvitesCreated", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedBy   User?     @relation("InviteAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([expiresAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Trade {
  id            String           @id @default(cuid())
  userId        String
  tradingAccountId String?
  broker        String?
  accountName   String?
  instrument    String
  direction     TradeDirection
  entryTime     DateTime
  exitTime      DateTime?
  entryPrice    Decimal          @db.Decimal(18, 6)
  exitPrice     Decimal?         @db.Decimal(18, 6)
  quantity      Decimal          @db.Decimal(18, 4)
  grossPnl      Decimal?         @db.Decimal(18, 2)
  netPnl        Decimal          @db.Decimal(18, 2)
  commission    Decimal?         @db.Decimal(18, 2)
  fees          Decimal?         @db.Decimal(18, 2)
  riskAmount    Decimal?         @db.Decimal(18, 2)
  rMultiple     Decimal?         @db.Decimal(10, 4)
  stopLoss      Decimal?         @db.Decimal(18, 6)
  takeProfit    Decimal?         @db.Decimal(18, 6)
  session       TradingSession   @default(OTHER)
  setupId       String?
  notes         String?
  emotionBefore String?
  emotionAfter  String?
  mistakeTags   String[]         @default([])
  screenshotUrl String?
  importedFrom  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  setup         Setup?           @relation(fields: [setupId], references: [id], onDelete: SetNull)
  tradingAccount TradingAccount? @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, entryTime])
  @@index([userId, tradingAccountId])
  @@index([userId, instrument])
  @@index([userId, setupId])
  @@index([userId, session])
}

model Setup {
  id                   String   @id @default(cuid())
  userId               String
  name                 String
  description          String?
  rules                Json?
  marketConditions     String?
  entryCriteria        String?
  exitCriteria         String?
  invalidationCriteria String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades               Trade[]

  @@unique([userId, name])
}

model ImportJob {
  id           String          @id @default(cuid())
  userId       String
  tradingAccountId String?
  source       String
  filename     String
  status       ImportJobStatus @default(PENDING)
  rowsTotal    Int            @default(0)
  rowsImported Int            @default(0)
  rowsFailed   Int            @default(0)
  errorLog     Json?
  createdAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradingAccount TradingAccount? @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, tradingAccountId])
}

model AIInsight {
  id              String   @id @default(cuid())
  userId          String
  insightType     String
  accountIds      String[] @default([])
  title           String
  summary         String
  evidence        Json
  suggestedAction String
  confidenceScore Decimal  @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, insightType])
}

model BrokerConnection {
  id                 String                 @id @default(cuid())
  userId             String
  provider           BrokerProvider
  environment        BrokerEnvironment      @default(LIVE)
  status             BrokerConnectionStatus @default(CONNECTED)
  externalUserId      String?
  accessToken         String                 @db.Text
  tokenType           String?
  expiresAt           DateTime
  lastTokenRefreshAt  DateTime?
  lastSyncedAt        DateTime?
  error               String?
  metadata            Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  user                User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts            BrokerAccount[]
  syncJobs            BrokerSyncJob[]

  @@unique([userId, provider, environment])
  @@index([provider, status, expiresAt])
}

model BrokerAccount {
  id                String           @id @default(cuid())
  userId            String
  connectionId      String
  tradingAccountId  String?
  provider          BrokerProvider
  externalAccountId String
  name              String
  accountSpec       String?
  enabled           Boolean          @default(false)
  lastSyncedAt      DateTime?
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection        BrokerConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  tradingAccount    TradingAccount?  @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)
  syncJobs          BrokerSyncJob[]

  @@unique([connectionId, externalAccountId])
  @@index([userId, tradingAccountId])
  @@index([userId, provider, enabled])
}

model BrokerSyncJob {
  id            String              @id @default(cuid())
  userId        String
  connectionId  String
  accountId     String?
  provider      BrokerProvider
  status        BrokerSyncJobStatus @default(PROCESSING)
  startedAt     DateTime            @default(now())
  finishedAt    DateTime?
  rowsFound     Int                 @default(0)
  rowsImported  Int                 @default(0)
  rowsFailed    Int                 @default(0)
  errorLog      Json?
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection    BrokerConnection    @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  account       BrokerAccount?      @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, provider, startedAt])
  @@index([connectionId, startedAt])
}
