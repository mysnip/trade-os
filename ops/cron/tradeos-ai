SHELL=/bin/bash
CRON_SECRET=replace-with-the-same-value-as-env
APP_URL=https://staging.example.com

*/15 * * * * curl -fsS -H "Authorization: Bearer ${CRON_SECRET}" "${APP_URL}/api/cron/tradovate/refresh-tokens" >/dev/null
*/30 * * * * curl -fsS -H "Authorization: Bearer ${CRON_SECRET}" "${APP_URL}/api/cron/tradovate/sync" >/dev/null
